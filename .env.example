# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clerk authentication
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Redis (Upstash KV) — used for rate limiting
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your-kv-token

# Cron endpoint protection
CRON_SECRET=your-random-secret

# AI providers (at least one recommended)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Google Calendar integration (optional)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/tours/gcal/callback

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Telnyx (SMS notifications)
TELNYX_API_KEY=KEY...
TELNYX_FROM_NUMBER=+15551234567

# Stripe billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# App URL
NEXT_PUBLIC_APP_URL=https://my.usechippi.com

# Phase D — auto-send for high-confidence drafts. When 'true', drafts with
# confidence >= 80 show a 30-second countdown that auto-fires the existing
# approve handler unless the realtor cancels. Default off; flip per-deploy.
NEXT_PUBLIC_AGENT_AUTO_SEND=false

# Modal Sandbox-backed Cowork chat. /api/ai/task proxies to this endpoint;
# Modal spawns a fresh Sandbox per turn and streams JSONL events back.
# Get the URL from `modal deploy agent/modal_app.py` (the chat_turn webhook).
MODAL_CHAT_URL=https://<your-modal-org>--chippi-agent-chat-turn.modal.run

# Shared secret between Next.js and Modal — must match the AGENT_INTERNAL_SECRET
# set in the chippi-secrets Modal secret. Used by both /api/agent/run-now and
# /api/ai/task to authorize cross-system calls.
AGENT_INTERNAL_SECRET=replace-with-a-long-random-string
