generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  space     Space?
}

model Space {
  id        String   @id @default(cuid())
  subdomain String   @unique
  name      String
  emoji     String
  createdAt DateTime @default(now())
  ownerId   String   @unique
  owner     User     @relation(fields: [ownerId], references: [id])

  contacts            Contact[]
  deals               Deal[]
  stages              DealStage[]
  messages            Message[]
  settings            SpaceSetting?
  vapiAgent           VapiAgent?
  leads               Lead[]
  conversations       Conversation[]
  agentFlow           AgentFlow?
  rentalApplications  RentalApplication[]
}

model SpaceSetting {
  id                String  @id @default(cuid())
  spaceId           String  @unique
  space             Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  notifications     Boolean @default(true)
  timezone          String  @default("UTC")
  phoneNumber       String?
  myConnections     String?
  aiPersonalization String?
  billingSettings   String?
  anthropicApiKey   String?
}

model Contact {
  id                  String               @id @default(cuid())
  spaceId             String
  space               Space                @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  name                String
  email               String?
  phone               String?
  address             String?
  notes               String?
  budget              Float?
  preferences         String?
  properties          String[]             @default([])
  type                ClientType           @default(QUALIFICATION)
  tags                String[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  dealContacts        DealContact[]
  rentalApplications  RentalApplication[]
}

enum ClientType {
  QUALIFICATION
  TOUR
  APPLICATION
}

model Deal {
  id           String        @id @default(cuid())
  spaceId      String
  space        Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  value        Float?
  address      String?
  priority     Priority      @default(MEDIUM)
  closeDate    DateTime?
  stageId      String
  stage        DealStage     @relation(fields: [stageId], references: [id])
  position     Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  dealContacts DealContact[]
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model DealStage {
  id       String @id @default(cuid())
  spaceId  String
  space    Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  name     String
  color    String @default("#6366f1")
  position Int    @default(0)
  deals    Deal[]
}

model DealContact {
  dealId    String
  contactId String
  deal      Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([dealId, contactId])
}

model Message {
  id        String   @id @default(cuid())
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())
}

model VapiAgent {
  id                String      @id @default(cuid())
  spaceId           String      @unique
  space             Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  vapiAssistantId   String      @unique
  vapiPhoneNumberId String?
  phoneNumber       String
  twilioSid         String?
  greeting          String?
  market            String?
  brokerageName     String?
  status            AgentStatus @default(ACTIVE)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

enum AgentStatus {
  ACTIVE
  ERROR
  INACTIVE
}

model Lead {
  id               String    @id @default(cuid())
  spaceId          String
  space            Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  callId           String    @unique
  phone            String
  score            LeadScore @default(COLD)
  intent           LeadIntent?
  budget           String?
  timeline         String?
  preferredAreas   String[]  @default([])
  preApproved      Boolean   @default(false)
  transcriptSummary String?
  transcript       String?
  recordingUrl     String?
  callDuration     Int?
  createdAt        DateTime  @default(now())
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum LeadIntent {
  BUYER
  SELLER
  BOTH
}

model Conversation {
  id              String           @id @default(cuid())
  spaceId         String
  space           Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  vapiCallId      String           @unique
  type            ConversationType
  status          String           @default("ended")
  phone           String?
  startedAt       DateTime?
  endedAt         DateTime?
  durationSeconds Int?
  summary         String?
  transcript      String?
  messages        Json?
  recordingUrl    String?
  cost            Float?
  createdAt       DateTime         @default(now())
}

enum ConversationType {
  VOICE_INBOUND
  VOICE_OUTBOUND
  SMS
}

model AgentFlow {
  id        String   @id @default(cuid())
  spaceId   String   @unique
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  nodes     Json     @default("[]")
  edges     Json     @default("[]")
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Rental Application Models ───────────────────────────────────────────────

model RentalApplication {
  id              String              @id @default(cuid())
  spaceId         String
  space           Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?            @relation(fields: [contactId], references: [id])

  // Property selection
  propertyAddress String?
  unitType        String?
  targetMoveIn    DateTime?
  monthlyRent     Float?
  leaseTerm       String?
  occupantCount   Int?

  // Status & progress
  status          ApplicationStatus   @default(DRAFT)
  currentStep     Int                 @default(1)
  completedSteps  String[]            @default([])

  // Rule-based qualification (deterministic, always runs)
  summary         String?
  qualScore       QualScore?

  // AI scoring (OpenAI Responses API, runs async after submission)
  aiScore          Int?       // 0–100 priority score
  aiPriorityLabel  String?    // hot | warm | cold | review
  aiSummary        String?    // 1–3 sentence triage summary
  aiReasonTags     Json?      // ["affordable", "docs complete", ...]
  aiWatchouts      Json?      // ["income tight", "missing docs", ...]
  aiConfidence     String?    // low | medium | high
  aiScoredAt       DateTime?
  aiScoringVersion String?
  aiScoringPayload Json?      // sanitized payload sent — no PII

  submittedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  applicants      RentalApplicant[]
  documents       ApplicationDocument[]

  @@index([spaceId])
  @@index([contactId])
}

enum ApplicationStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum QualScore {
  HOT
  WARM
  COLD
}

model RentalApplicant {
  id            String            @id @default(cuid())
  applicationId String
  application   RentalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  isPrimary     Boolean           @default(true)

  // Basics
  legalName     String?
  email         String?
  phone         String?
  dateOfBirth   DateTime?
  idLastFour    String?

  // Current living situation
  currentAddress  String?
  housingStatus   HousingStatus?
  currentPayment  Float?
  lengthAtAddress String?
  reasonForMoving String?

  // Household
  adultsOnApp           Int?
  children              Int?
  roommates             Int?
  emergencyContactName  String?
  emergencyContactPhone String?

  // Income
  employmentStatus   EmploymentStatus?
  employerName       String?
  monthlyGrossIncome Float?
  additionalIncome   Float?

  // Rental history
  currentLandlordName  String?
  currentLandlordPhone String?
  prevLandlordName     String?
  prevLandlordPhone    String?
  rentPaidOnTime       Boolean?
  latePayments         Int?
  leaseViolations      Boolean?
  referencePermission  Boolean?

  // Screening
  priorEvictions      Boolean?
  outstandingBalances Boolean?
  bankruptcy          Boolean?
  backgroundConsent   Boolean?
  hasPets             Boolean?
  petDetails          String?
  smokingDeclaration  Boolean?

  // Consents
  screeningConsent    Boolean?
  truthCertification  Boolean?
  electronicSignature String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
}

enum HousingStatus {
  OWN
  RENT
  RENT_FREE
}

enum EmploymentStatus {
  FULL_TIME
  PART_TIME
  SELF_EMPLOYED
  UNEMPLOYED
  RETIRED
  STUDENT
  OTHER
}

model ApplicationDocument {
  id            String            @id @default(cuid())
  applicationId String
  application   RentalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicantId   String?
  type          DocType
  fileName      String
  fileUrl       String
  uploadedAt    DateTime          @default(now())

  @@index([applicationId])
}

enum DocType {
  GOVERNMENT_ID
  PAY_STUB
  BANK_STATEMENT
  OFFER_LETTER
  PET_DOCUMENTATION
  OTHER
}
